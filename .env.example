# Anthropic API key — powers AI summaries on each page
VITE_ANTHROPIC_API_KEY=sk-ant-...

# GitHub Gist storage — leave blank to use local Express server (npm run server)
# See setup instructions below for how to create these
VITE_GIST_ID=
VITE_GITHUB_TOKEN=

# SHA-256 hex of your chosen password (leave blank to skip password gate in local dev)
# Generate with: echo -n 'YourPassword' | shasum -a 256 | awk '{print $1}'
VITE_APP_PASSWORD_HASH=
